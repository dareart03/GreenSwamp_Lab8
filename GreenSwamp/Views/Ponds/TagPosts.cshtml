@model List<GreenSwamp.Models.Post>
@{
    ViewData["Title"] = "#" + ViewBag.TagName;
    var tagName = ViewBag.TagName as string;
    var tag = ViewBag.Tag as GreenSwamp.Models.Tag;
    var interactions = ViewBag.PostInteractions as Dictionary<int, Dictionary<string, int>>;
    var trendingPonds = ViewBag.TrendingPonds as List<GreenSwamp.Data.TrendingPond>;

    string FormatContent(string content)
    {
        var regex = new System.Text.RegularExpressions.Regex(@"#(\w+)");
        return regex.Replace(content, "<a href='/ponds/$1' class='text-swamp-600 hover:underline'>#$1</a>");
    }
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Main Feed -->
        <div class="lg:col-span-3 space-y-6">

            <!-- Pond Header -->
            <div class="bg-white rounded-xl shadow-sm p-6 border border-swamp-200">
                <div class="flex items-center space-x-4">
                    <div class="w-14 h-14 rounded-full bg-swamp-100 flex items-center justify-center text-2xl">🌿</div>
                    <div>
                        <h1 class="text-2xl font-bold text-swamp-900">#@tagName</h1>
                        <p class="text-swamp-500 text-sm">@Model.Count posts in this pond</p>
                    </div>
                </div>
            </div>

            <!-- Posts -->
            @if (!Model.Any())
            {
                <div class="bg-white rounded-xl shadow-sm p-12 border border-swamp-200 text-center">
                    <p class="text-swamp-500 text-lg">No posts in this pond yet 🐸</p>
                    <a href="/feed" class="mt-4 inline-block text-swamp-600 hover:underline">Back to feed</a>
                </div>
            }

            @foreach (var post in Model)
            {
                <div class="bg-white rounded-xl shadow-sm p-6 border border-swamp-200">
                    <div class="flex items-start space-x-4">
                        <a href="/profile/@post.User.Username">
                            <img src="@(post.User.AvatarUrl ?? "/images/default-avatar.svg")"
                                 alt="@post.User.DisplayName"
                                 class="w-12 h-12 rounded-full object-cover">
                        </a>
                        <div class="flex-1">
                            <div class="flex items-center space-x-2">
                                <a href="/profile/@post.User.Username" class="font-semibold text-swamp-900 hover:underline">
                                    @post.User.DisplayName
                                </a>
                                <span class="text-swamp-500">@@@post.User.Username</span>
                                <span class="text-swamp-400">·</span>
                                <span class="text-swamp-500 text-sm">@post.CreatedAt.ToString("MMM d")</span>
                            </div>

                            <a href="/feed/post/@post.PostId" class="block mt-2">
                                <p class="text-swamp-800">@Html.Raw(FormatContent(post.Content))</p>
                            </a>

                            @if (post.PostType != "text" && !string.IsNullOrEmpty(post.MediaUrl))
                            {
                                <div class="mt-4">
                                    @if (post.PostType == "image")
                                    {
                                        <img src="@post.MediaUrl" alt="@post.AltText"
                                             class="rounded-lg max-h-96 w-full object-cover">
                                    }
                                    else if (post.PostType == "video")
                                    {
                                        <video controls class="rounded-lg w-full">
                                            <source src="@post.MediaUrl" type="video/mp4">
                                        </video>
                                    }
                                </div>
                            }

                            @if (post.Event != null)
                            {
                                <div class="mt-4 p-4 bg-swamp-50 rounded-lg border border-swamp-200">
                                    <h4 class="font-semibold text-swamp-900">📅 Event</h4>
                                    <p class="text-swamp-700">@post.Event.Location</p>
                                    <p class="text-swamp-600 text-sm">@post.Event.EventTime.ToString("MMM d, yyyy - h:mm tt")</p>
                                    @if (post.Event.HostOrg != null)
                                    {
                                        <p class="text-swamp-600 text-sm">Hosted by: @post.Event.HostOrg</p>
                                    }
                                </div>
                            }

                            <div class="mt-3 flex flex-wrap gap-2">
                                @foreach (var postTag in post.PostTags)
                                {
                                    <a href="/ponds/@postTag.Tag.TagName"
                                       class="text-sm px-3 py-1 rounded-full @(postTag.Tag.TagName == tagName ? "bg-swamp-600 text-white" : "bg-swamp-100 text-swamp-600 hover:bg-swamp-200")">
                                        #@postTag.Tag.TagName
                                    </a>
                                }
                            </div>

                            <div class="mt-4 flex items-center space-x-6">
                                <span class="flex items-center space-x-2 text-swamp-600">
                                    <span>💬</span>
                                    <span>@(interactions?[post.PostId]?["comments"] ?? 0)</span>
                                </span>
                                <span class="flex items-center space-x-2 text-swamp-600">
                                    <span>🔄</span>
                                    <span>@(interactions?[post.PostId]?["reribbs"] ?? 0)</span>
                                </span>
                                <span class="flex items-center space-x-2 text-swamp-600">
                                    <span>❤️</span>
                                    <span>@(interactions?[post.PostId]?["likes"] ?? 0)</span>
                                </span>
                                @if (post.Event != null)
                                {
                                    <span class="flex items-center space-x-2 text-swamp-600">
                                        <span>📅</span>
                                        <span>@(interactions?[post.PostId]?["rsvps"] ?? 0)</span>
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-sm p-6 border border-swamp-200 sticky top-6">
                <h3 class="font-semibold text-swamp-900 mb-4">Trending Ponds</h3>
                @if (trendingPonds != null && trendingPonds.Any())
                {
                    <div class="space-y-3">
                        @foreach (var pond in trendingPonds)
                        {
                            <a href="/ponds/@pond.TagName"
                               class="block p-3 rounded-lg transition-colors @(pond.TagName == tagName ? "bg-swamp-600 text-white" : "bg-swamp-50 hover:bg-swamp-100")">
                                <span class="font-medium @(pond.TagName == tagName ? "text-white" : "text-swamp-800")">#@pond.TagName</span>
                                <span class="text-sm ml-2 @(pond.TagName == tagName ? "text-swamp-100" : "text-swamp-500")">@pond.RecentPosts posts</span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-swamp-500">No trending ponds yet</p>
                }
            </div>
        </div>

    </div>
</div>

@model GreenSwamp.Models.Post
@{
    ViewData["Title"] = "Post by " + Model.User.DisplayName;
    var counts = ViewBag.InteractionCounts as Dictionary<string, int>;
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Main Post -->
    <div class="bg-white rounded-xl shadow-sm p-6 border border-swamp-200 mb-6">
        <div class="flex items-start space-x-4">
            <a href="/profile/@Model.User.Username">
                <img src="@(Model.User.AvatarUrl ?? "/images/default-avatar.svg")" 
                     alt="@Model.User.DisplayName"
                     class="w-12 h-12 rounded-full object-cover">
            </a>
            <div class="flex-1">
                <div class="flex items-center space-x-2">
                    <a href="/profile/@Model.User.Username" class="font-semibold text-swamp-900 hover:underline">
                        @Model.User.DisplayName
                    </a>
                    <span class="text-swamp-500">@@@Model.User.Username</span>
                    <span class="text-swamp-400">·</span>
                    <span class="text-swamp-500 text-sm">
                        @Model.CreatedAt.ToString("MMM d, yyyy")
                    </span>
                </div>
                <p class="mt-2 text-lg text-swamp-800">@Model.Content</p>
            </div>
        </div>

        <!-- Media -->
        @if (Model.PostType != "text" && !string.IsNullOrEmpty(Model.MediaUrl))
        {
            <div class="mt-4">
                @if (Model.PostType == "image")
                {
                    <img src="@Model.MediaUrl" alt="@Model.AltText" 
                         class="rounded-lg max-h-96 w-full object-cover">
                }
                else if (Model.PostType == "video")
                {
                    <video controls class="rounded-lg w-full">
                        <source src="@Model.MediaUrl" type="video/mp4">
                    </video>
                }
            </div>
        }

        <!-- Event Info -->
        @if (Model.Event != null)
        {
            <div class="mt-4 p-4 bg-swamp-50 rounded-lg border border-swamp-200">
                <h4 class="font-semibold text-swamp-900">📅 Event Details</h4>
                <p class="text-swamp-700 mt-1">📍 @Model.Event.Location</p>
                <p class="text-swamp-700">🕐 @Model.Event.EventTime.ToString("MMM d, yyyy - h:mm tt")</p>
                @if (Model.Event.HostOrg != null)
                {
                    <p class="text-swamp-700">🏢 @Model.Event.HostOrg</p>
                }
                @if (Model.Event.MaxCapacity.HasValue)
                {
                    <p class="text-swamp-700">👥 @Model.Event.RsvpCount / @Model.Event.MaxCapacity attending</p>
                }
            </div>
        }

        <!-- Tags -->
        @if (Model.PostTags.Any())
        {
            <div class="mt-3 flex flex-wrap gap-2">
                @foreach (var postTag in Model.PostTags)
                {
                    <a href="/ponds/@postTag.Tag.TagName" 
                       class="text-sm text-swamp-600 hover:text-swamp-800 bg-swamp-100 px-3 py-1 rounded-full">
                        #@postTag.Tag.TagName
                    </a>
                }
            </div>
        }

        <!-- Interactions -->
        <div class="mt-6 flex items-center space-x-6 border-t border-swamp-200 pt-4">
            <span class="flex items-center space-x-2 text-swamp-600">
                <span>💬</span>
                <span>@counts["comments"]</span>
            </span>
            <span class="flex items-center space-x-2 text-swamp-600">
                <span>🔄</span>
                <span>@counts["reribbs"]</span>
            </span>
            <span class="flex items-center space-x-2 text-swamp-600">
                <span>❤️</span>
                <span>@counts["likes"]</span>
            </span>
        </div>
    </div>

    <!-- Replies -->
    @if (Model.Replies.Any())
    {
        <div class="space-y-4">
            <h3 class="font-semibold text-swamp-900">Replies</h3>
            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedAt))
            {
                <div class="bg-white rounded-xl shadow-sm p-4 border border-swamp-200 ml-8">
                    <div class="flex items-start space-x-3">
                        <a href="/profile/@reply.User.Username">
                            <img src="@(reply.User.AvatarUrl ?? "/images/default-avatar.svg")" 
                                 alt="@reply.User.DisplayName"
                                 class="w-8 h-8 rounded-full object-cover">
                        </a>
                        <div class="flex-1">
                            <div class="flex items-center space-x-2">
                                <a href="/profile/@reply.User.Username" class="font-semibold text-swamp-900 hover:underline">
                                    @reply.User.DisplayName
                                </a>
                                <span class="text-swamp-500 text-sm">@@@reply.User.Username</span>
                            </div>
                            <p class="mt-1 text-swamp-800">@reply.Content</p>
                            <p class="mt-1 text-swamp-500 text-xs">
                                @reply.CreatedAt.ToString("MMM d, yyyy")
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
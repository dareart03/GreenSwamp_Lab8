@model GreenSwamp.Models.User
@{
    ViewData["Title"] = Model.DisplayName + " (@" + Model.Username + ")";
    var interactions = ViewBag.PostInteractions as Dictionary<int, Dictionary<string, int>>;
    var trendingPonds = ViewBag.TrendingPonds as List<GreenSwamp.Data.TrendingPond>;
    var upcomingEvents = ViewBag.UpcomingEvents as List<GreenSwamp.Models.Event>;
    bool isAuth = User.Identity?.IsAuthenticated == true;
    string? currentUsername = User.Identity?.Name;

    string FormatContent(string content)
    {
        var regex = new System.Text.RegularExpressions.Regex(@"#(\w+)");
        return regex.Replace(content, "<a href='/ponds/$1' class='text-swamp-600 hover:underline'>#$1</a>");
    }
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-0 lg:divide-x min-h-[calc(100vh-4rem)]">

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <div class="lg:col-span-1 bg-white">
            <div class="p-6 space-y-4">

                @if (isAuth)
                {
                    <div class="flex items-center space-x-3 pb-4 border-b border-swamp-100">
                        <a href="/profile/@currentUsername">
                            <img src="@(User.FindFirst("AvatarUrl")?.Value is { Length: > 0 } u ? u : $"https://api.dicebear.com/9.x/adventurer/svg?seed={Uri.EscapeDataString(currentUsername ?? "user")}&backgroundColor=b6e3f4,c0aede,d1d4f9,ffd5dc,ffdfbf")"
                                 class="w-12 h-12 rounded-full object-cover" alt="avatar">
                        </a>
                        <div>
                            <a href="/profile/@currentUsername" class="font-semibold text-swamp-900 text-sm hover:underline block">
                                @User.FindFirst("DisplayName")?.Value
                            </a>
                            <p class="text-xs text-swamp-500">@@@currentUsername</p>
                        </div>
                    </div>
                    
                    
                    <button onclick="openPostModal()"
                            class="w-full flex items-center justify-center space-x-2 bg-swamp-500 hover:bg-swamp-600 text-white px-4 py-2.5 rounded-full font-medium text-sm transition-colors">
                        <span>✏️</span><span>Написать Ribbit</span>
                    </button>
                    
                   
                    <a href="/account/logout?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)"
                       class="w-full flex items-center justify-center space-x-2 bg-red-50 hover:bg-red-100 text-red-600 px-4 py-2.5 rounded-full font-medium text-sm transition-colors border border-red-200">
                        <span>🚪</span><span>Выйти</span>
                    </a>
                }
                else
                {
                    <div class="p-4 bg-swamp-50 rounded-xl border border-swamp-200 text-center space-y-3">
                        <p class="text-swamp-700 text-sm font-medium">Присоединяйтесь! 🐸</p>
                        <a href="/account/register" class="block w-full bg-swamp-500 hover:bg-swamp-600 text-white py-2 rounded-full text-sm font-medium">Регистрация</a>
                        <a href="/account/login" class="block w-full border border-swamp-300 text-swamp-700 py-2 rounded-full text-sm font-medium hover:bg-swamp-50">Войти</a>
                    </div>
                }

                <nav class="space-y-1 pt-2">
                    <a href="/feed" class="flex items-center space-x-3 p-2 rounded-lg hover:bg-swamp-50 text-swamp-700">
                        <span class="text-xl">🐸</span><span>Swamp</span>
                    </a>
                    <a href="/ponds" class="flex items-center space-x-3 p-2 rounded-lg hover:bg-swamp-50 text-swamp-700">
                        <span class="text-xl">🌿</span><span>Ponds</span>
                    </a>
                </nav>

                @{
                    var userTags = Model.Posts
                        .SelectMany(p => p.PostTags)
                        .Select(pt => pt.Tag)
                        .Where(t => t != null)
                        .GroupBy(t => t.TagName)
                        .OrderByDescending(g => g.Count())
                        .Take(5)
                        .Select(g => g.First())
                        .ToList();
                }
                @if (userTags.Any())
                {
                    <div class="pt-2">
                        <p class="text-xs text-swamp-400 font-medium uppercase tracking-wide px-2 mb-2">Ponds</p>
                        <ul class="space-y-1">
                            @foreach (var tag in userTags)
                            {
                                <li>
                                    <a href="/ponds/@tag.TagName" class="flex items-center space-x-2 p-2 rounded-lg hover:bg-swamp-50">
                                        <span class="w-2 h-2 bg-swamp-400 rounded-full"></span>
                                        <span class="text-swamp-700 text-sm">#@tag.TagName</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        
        <div class="lg:col-span-2 divide-y bg-white">
           
            <div class="relative overflow-hidden">
                <div class="h-40 bg-gradient-to-br from-swamp-700 to-swamp-400 relative">
                    <div class="absolute -bottom-12 left-6 z-10">
                        <div class="w-24 h-24 rounded-full border-4 border-white overflow-hidden shadow-xl">
                            <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://api.dicebear.com/9.x/adventurer/svg?seed={Uri.EscapeDataString(Model.Username)}&backgroundColor=b6e3f4,c0aede,d1d4f9,ffd5dc,ffdfbf" : Model.AvatarUrl)"
                                 class="w-full h-full object-cover" alt="@Model.DisplayName">
                        </div>
                    </div>
                </div>
                <div class="pt-14 px-6 pb-5">
                    <div class="flex items-start justify-between">
                        <div>
                            <h1 class="text-xl font-bold text-swamp-900">@Model.DisplayName</h1>
                            <p class="text-swamp-500 text-sm">@@@Model.Username</p>
                        </div>
                        @if (isAuth && currentUsername == Model.Username)
                        {
                            <span class="text-xs bg-swamp-100 text-swamp-600 px-3 py-1 rounded-full">Это вы</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Bio))
                    {
                        <p class="mt-2 text-swamp-700 text-sm">@Model.Bio</p>
                    }
                    <p class="mt-1 text-xs text-swamp-400">
                        Joined @Model.CreatedAt.ToString("MMMM yyyy") · @Model.Posts.Count posts
                    </p>
                </div>
            </div>

            
            @if (!Model.Posts.Any())
            {
                <div class="p-12 text-center text-swamp-400">
                    <p class="text-4xl mb-3">🐸</p>
                    <p>Постов пока нет</p>
                </div>
            }

            @foreach (var post in Model.Posts)
            {
                <div class="p-5">
                    <div class="flex items-start space-x-3">
                        <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://api.dicebear.com/9.x/adventurer/svg?seed={Uri.EscapeDataString(Model.Username)}&backgroundColor=b6e3f4,c0aede,d1d4f9,ffd5dc,ffdfbf" : Model.AvatarUrl)"
                             alt="@Model.DisplayName" class="w-10 h-10 rounded-full object-cover flex-shrink-0">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center space-x-2 flex-wrap">
                                <span class="font-semibold text-swamp-900 text-sm">@Model.DisplayName</span>
                                <span class="text-swamp-400 text-xs">@@@Model.Username</span>
                                <span class="text-swamp-200 text-xs">·</span>
                                <a href="/feed/post/@post.PostId" class="text-xs text-swamp-400 hover:text-swamp-600">
                                    @post.CreatedAt.ToString("MMM d, yyyy")
                                </a>
                            </div>

                            <a href="/feed/post/@post.PostId" class="block mt-1">
                                <p class="text-swamp-800 text-sm leading-relaxed">@Html.Raw(FormatContent(post.Content))</p>
                            </a>

                            @if (post.PostType != "text" && !string.IsNullOrEmpty(post.MediaUrl))
                            {
                                <div class="mt-3 rounded-xl overflow-hidden border border-swamp-100">
                                    @if (post.PostType == "image")
                                    {
                                        <img src="@post.MediaUrl" alt="@post.AltText" class="w-full max-h-72 object-cover">
                                    }
                                    else if (post.PostType == "video")
                                    {
                                        <video controls class="w-full"><source src="@post.MediaUrl" type="video/mp4"></video>
                                    }
                                </div>
                            }

                            @if (post.Event != null)
                            {
                                <div class="mt-3 p-3 bg-swamp-50 rounded-xl border border-swamp-200">
                                    <p class="font-semibold text-swamp-900 text-sm">📅 @post.Event.Location</p>
                                    <p class="text-swamp-500 text-xs">@post.Event.EventTime.ToString("ddd, MMM d · h:mm tt")</p>
                                    @if (post.Event.HostOrg != null) { <p class="text-xs text-swamp-400">by @post.Event.HostOrg</p> }
                                </div>
                            }

                            @if (post.PostTags.Any())
                            {
                                <div class="mt-2 flex flex-wrap gap-1">
                                    @foreach (var pt in post.PostTags)
                                    {
                                        <a href="/ponds/@pt.Tag.TagName"
                                           class="text-xs text-swamp-600 bg-swamp-100 hover:bg-swamp-200 px-2 py-0.5 rounded-full">#@pt.Tag.TagName</a>
                                    }
                                </div>
                            }

                            <div class="mt-3 flex items-center space-x-5 text-swamp-400 text-xs">
                                <span class="flex items-center space-x-1">
                                    <span>💬</span>
                                    <span>@(interactions?.GetValueOrDefault(post.PostId)?.GetValueOrDefault("comments") ?? 0)</span>
                                </span>
                                <span class="flex items-center space-x-1">
                                    <span>🔄</span>
                                    <span>@(interactions?.GetValueOrDefault(post.PostId)?.GetValueOrDefault("reribbs") ?? 0)</span>
                                </span>
                                <span class="flex items-center space-x-1">
                                    <span>❤️</span>
                                    <span>@(interactions?.GetValueOrDefault(post.PostId)?.GetValueOrDefault("likes") ?? 0)</span>
                                </span>
                                @if (post.Event != null)
                                {
                                    <span class="flex items-center space-x-1">
                                        <span>📅</span>
                                        <span>@(interactions?.GetValueOrDefault(post.PostId)?.GetValueOrDefault("rsvps") ?? 0)</span>
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

       
        <div class="lg:col-span-1 bg-white">
            <div class="p-6 space-y-6">
               
                <div>
                    <h3 class="text-base font-semibold text-swamp-900 mb-3">Trending Ponds</h3>
                    @if (trendingPonds != null && trendingPonds.Any())
                    {
                        <ul class="space-y-2">
                            @foreach (var pond in trendingPonds)
                            {
                                <li>
                                    <a href="/ponds/@pond.TagName" class="flex items-center space-x-3 p-2 rounded-lg hover:bg-swamp-50 group">
                                        <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center text-swamp-600 font-bold text-xs">#</div>
                                        <div>
                                            <p class="font-medium text-swamp-900 text-sm group-hover:text-swamp-600">#@pond.TagName</p>
                                            <p class="text-xs text-swamp-400">@pond.RecentPosts posts</p>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else { <p class="text-swamp-400 text-sm">No trending ponds yet</p> }
                </div>
            </div>
        </div>
    </div>
</div>
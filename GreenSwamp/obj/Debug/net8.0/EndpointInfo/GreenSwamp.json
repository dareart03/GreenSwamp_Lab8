    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "AuthApi"
        ],
        "summary": "Получить JWT-токен по логину и паролю",
        "description": "Пример запроса:\r\n            \r\n    POST /api/v1/auth/login\r\n    { \"username\": \"lily_pad\", \"password\": \"password123\" }\r\n            \r\nПолученный token вставляй в Swagger через кнопку Authorize (Bearer схема).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/feed": {
      "get": {
        "tags": [
          "Feed"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/interactions": {
      "get": {
        "tags": [
          "InteractionsApi"
        ],
        "summary": "Получить взаимодействия с фильтрами",
        "parameters": [
          {
            "name": "postId",
            "in": "query",
            "description": "Фильтр по посту",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "description": "Фильтр по пользователю",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Фильтр по типу: like / reribb / comment / rsvp",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/InteractionResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "InteractionsApi"
        ],
        "summary": "Добавить взаимодействие (лайк / reribb / comment / rsvp)",
        "description": "🔒 Требует JWT.\r\nНа один пост можно оставить только одно взаимодействие каждого типа.\r\nПоле content обязательно только для type = \"comment\".",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInteractionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInteractionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInteractionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InteractionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/interactions/{id}": {
      "delete": {
        "tags": [
          "InteractionsApi"
        ],
        "summary": "Удалить своё взаимодействие (убрать лайк, etc.)",
        "description": "🔒 Требует JWT. Можно удалить только своё взаимодействие.\r\nПри удалении взаимодействие удаляется физически (не мягко).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },

@page
@model GreenSwamp.Pages.registerModel
@{
}
<!-- Background overlay -->
    <div class="fixed inset-0 swamp-bg -z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-swamp-50/90 to-swamp-100/60 z-0"></div>
    
    <!-- Content container -->
    <div class="relative z-10">
        <!-- Main Container -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <!-- Logo Header -->
            <div class="text-center mb-16">
                <div class="flex items-center justify-center space-x-3 mb-6">
                    <img src="~/green-toad-logo.svg" alt="Greenswamp Logo" class="h-16 w-16">
                    <span class="text-4xl font-bold text-swamp-900">Greenswamp</span>
                </div>
                <p class="text-lg text-swamp-800">Join the pond community</p>
            </div>

            <!-- Registration Card -->
            <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-lg p-8 sm:p-12 border border-swamp-100">
                @if (ViewData["Error"] != null)
                {
                    <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">@ViewData["Error"]</div>
                }
                <form method="post" action="/account/register" class="space-y-8">
                    <!-- Username -->
                    <div class="space-y-2">
                        <label class="block text-base font-semibold text-swamp-900">Username</label>
                        <input type="text" name="username" required autofocus
                            class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                                   border border-swamp-200 focus:border-swamp-400 
                                   focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                                   text-slate-900 shadow-sm"
                            placeholder="cool_frog_42">
                        <p class="text-xs text-swamp-500">Только буквы, цифры и _</p>
                    </div>

                    <!-- Display Name -->
                    <div class="space-y-2">
                        <label class="block text-base font-semibold text-swamp-900">Display Name</label>
                        <input type="text" name="displayName" required 
                            class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                                   border border-swamp-200 focus:border-swamp-400 
                                   focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                                   text-slate-900 shadow-sm"
                            placeholder="Princess Toadstool">
                    </div>
    
                    <!-- Password -->
                    <div class="space-y-2">
                        <label class="block text-base font-semibold text-swamp-900">Password</label>
                        <input type="password" name="password" required 
                            class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                                   border border-swamp-200 focus:border-swamp-400 
                                   focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                                   text-slate-900 shadow-sm"
                            placeholder="••••••••">
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-2">
                        <label class="block text-base font-semibold text-swamp-900">Confirm Password</label>
                        <input type="password" name="confirmPassword" required 
                            class="mt-1 block w-full rounded-xl bg-white px-5 py-3.5
                                   border border-swamp-200 focus:border-swamp-400 
                                   focus:ring-2 focus:ring-swamp-200 placeholder-slate-400
                                   text-slate-900 shadow-sm"
                            placeholder="••••••••">
                    </div>
    
                    <!-- Submit Button -->
                    <button type="submit" 
                        class="w-full bg-gradient-to-br from-swamp-500 to-swamp-600 text-white 
                               py-4 px-6 rounded-xl hover:from-swamp-600 hover:to-swamp-700 
                               focus:ring-2 focus:ring-swamp-400 font-semibold
                               transition-all duration-200 shadow-lg">
                        Create Account
                    </button>
    
                    <!-- Login Link -->
                    <p class="text-center text-swamp-700 mt-8">
                        Already have an account? 
                        <a asp-page="/login" class="font-semibold text-swamp-800 hover:text-swamp-900 underline">
                            Log in here
                        </a>
                    </p>
                </form>
            </div>


            <!-- Footer Links -->
            <div class="mt-16 text-center">
                <div class="flex items-center justify-center space-x-4 text-swamp-700">
                    <a asp-page="/privacy" class="hover:text-swamp-900 hover:underline">Privacy</a>
                    <span class="text-swamp-500">•</span>
                    <a asp-page="/tos" class="hover:text-swamp-900 hover:underline">Terms</a>
                    <span class="text-swamp-500">•</span>
                    <a asp-page="/Contact" class="hover:text-swamp-900 hover:underline">Contact</a>
                </div>
            </div>
        </div>
    </div>
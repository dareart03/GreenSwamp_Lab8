@page

<!-- Hero Section — фоновое изображение с градиентом и призывом к действию -->
<div class="relative h-[500px]">

    <!-- Фоновое фото кампуса с тёмным градиентом снизу -->
    <div class="absolute inset-0 z-0">
        <img src="~/istockphoto-831860650-1024x1024.jpg" alt="Campus green space with students"
             class="w-full h-full object-cover object-center">
        <div class="absolute inset-0 bg-gradient-to-t from-swamp-900/80 to-swamp-900/20"></div>
    </div>

    <!-- Текст поверх фото -->
    <div class="relative z-10 h-full flex items-center">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl font-extrabold text-white sm:text-5xl md:text-6xl">
                Hop Into Campus Life
            </h1>
            <p class="mt-4 max-w-md mx-auto text-lg text-swamp-300 sm:text-xl md:mt-6 md:max-w-2xl">
                Connect with classmates through lilypad groups and swamp chats.
            </p>
            <!-- Кнопки CTA: перейти в ленту или зарегистрироваться -->
            <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/feed"
                   class="bg-swamp-500 text-white px-8 py-3 rounded-full text-lg font-semibold hover:bg-swamp-600 transition-colors">
                    New Ribbit
                </a>
                <a href="/account/register"
                   class="bg-white text-swamp-700 px-8 py-3 rounded-full text-lg font-semibold hover:bg-swamp-100 transition-colors border border-swamp-200">
                    Join the Swamp
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Features Grid — три карточки с описанием функций платформы -->
<div class="max-w-7xl mx-auto py-16 px-4 sm:py-24 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8">

        <!-- Карточка 1: Quick Ribbits — короткие посты -->
        <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-swamp-100 rounded-lg flex items-center justify-center">
                <svg class="text-swamp-600" fill="currentColor" height="48" width="48" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Quick Ribbits</h3>
            <p class="mt-2 text-swamp-600">Share short updates, questions, or campus alerts in 280 characters or less.</p>
        </div>

        <!-- Карточка 2: Pond Groups — группы по интересам -->
        <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-swamp-100 rounded-lg flex items-center justify-center">
                <svg class="text-swamp-600" fill="currentColor" height="48" width="48" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Pond Groups</h3>
            <p class="mt-2 text-swamp-600">Join or create groups for your dorm, classes, clubs, or interests.</p>
        </div>

        <!-- Карточка 3: Firefly Events — события кампуса -->
        <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-swamp-100 rounded-lg flex items-center justify-center">
                <svg class="text-swamp-600" fill="currentColor" height="48" width="48" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
                </svg>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-swamp-900">Firefly Events</h3>
            <p class="mt-2 text-swamp-600">Never miss a campus event, party, or study session again.</p>
        </div>

    </div>
</div>

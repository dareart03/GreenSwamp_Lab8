<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Greenswamp</title>
    <link rel="icon" type="image/svg+xml" href="~/green-toad-logo.svg">

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        swamp: {
                            50: '#f0fdf4',
                            100: '#dcfce7',
                            200: '#bbf7d0',
                            300: '#86efac',
                            400: '#4ade80',
                            500: '#22c55e',
                            600: '#16a34a',
                            700: '#15803d',
                            800: '#166534',
                            900: '#14532d',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        #mobile-menu {
            transition: all 0.3s ease-out;
            transform-origin: top;
        }

        #mobile-menu.hidden {
            opacity: 0;
            transform: scaleY(0);
        }

        #mobile-menu.block {
            opacity: 1;
            transform: scaleY(1);
        }
    </style>
</head>

<body class="bg-swamp-50">

<!-- NAVBAR -->
<nav class="bg-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between items-center h-16">

            <a href="/" class="flex items-center space-x-2">
                <img src="~/green-toad-logo.svg" class="h-8 w-8">
                <span class="text-2xl font-bold text-swamp-600">Greenswamp</span>
            </a>

            <div class="hidden md:flex space-x-8">
                <a href="/About" class="my-auto text-swamp-600">About</a>
                <a href="/Contact" class="my-auto text-swamp-600">Contact</a>
                <a href="/Privacy" class="my-auto text-swamp-600">Privacy</a>
                <a href="/Tos" class="my-auto text-swamp-600">Terms</a>
            </div>

            <button id="mobile-menu-button" class="md:hidden text-swamp-600">
                ☰
            </button>
        </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden absolute w-full bg-white shadow-lg">
        <div class="px-4 py-2 space-y-4">
            <a href="/About">About</a>
            <a href="/Contact">Contact</a>
            <a href="/Privacy">Privacy</a>
            <a href="/Tos">Terms</a>
        </div>
    </div>
</nav>

<!-- ВАЖНО -->
@RenderBody()

    <!-- Subscribe Notification -->
    @if (TempData["SubscribeSuccess"] != null || TempData["SubscribeError"] != null)
    {
        <div class="fixed bottom-6 right-6 z-[200] px-6 py-4 rounded-2xl shadow-xl text-white flex items-center gap-3 max-w-xs">
            @if (TempData["SubscribeSuccess"] != null)
            {
                <div class="bg-green-600 rounded-2xl px-6 py-4">@TempData["SubscribeSuccess"]</div>
            }
            else if (TempData["SubscribeError"] != null)
            {
                <div class="bg-red-600 rounded-2xl px-6 py-4">@TempData["SubscribeError"]</div>
            }
        </div>
    }

<!-- FOOTER -->
<footer class="bg-swamp-900 text-white">
    <div class="max-w-7xl mx-auto py-12 px-4">
        <div class="grid md:grid-cols-3 gap-8">

            <div>
                <div class="flex items-center space-x-2">
                    <img src="~/green-toad-logo.svg" class="h-8 w-8">
                    <span class="text-xl font-bold">Greenswamp</span>
                </div>
                <p class="mt-4 text-sm text-swamp-300">
                    Connecting people one ribbit at a time.
                </p>
            </div>

            <div>
                <h4 class="text-sm font-semibold text-white">Links</h4>
                <ul class="mt-4 space-y-2 text-sm">
                    <li><a href="/About" class="text-swamp-300 hover:text-white">About</a></li>
                    <li><a href="/Contact" class="text-swamp-300 hover:text-white">Contact</a></li>
                    <li><a href="/Privacy" class="text-swamp-300 hover:text-white">Privacy</a></li>
                    <li><a href="/Tos" class="text-swamp-300 hover:text-white">Terms</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-sm font-semibold text-white">Stay Updated</h4>
                <p class="mt-2 text-sm text-swamp-300">Get the freshest ribbits in your inbox.</p>
                <form method="post" asp-controller="Subscribe" asp-action="Subscribe" class="mt-4 flex">
                    <input type="email"
                           name="Email"
                           placeholder="your@email.com"
                           required
                           class="px-4 py-2 rounded-l-full flex-1 text-swamp-900 focus:outline-none focus:ring-2 focus:ring-swamp-400">
                    <button type="submit"
                            class="bg-swamp-500 hover:bg-swamp-400 text-white px-4 py-2 rounded-r-full font-semibold transition-colors">
                        Subscribe
                    </button>
                </form>
            </div>

        </div>
    </div>
</footer>

<script>
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
    });
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
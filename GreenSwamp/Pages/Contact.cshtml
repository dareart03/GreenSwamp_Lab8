@page
@model GreenSwamp.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}

<section class="rounded-xl shadow-sm p-8">
    <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-swamp-900 mb-2">Swamp Mail</h2>
            <p class="text-swamp-700">Send a message that'll hop straight to our team</p>
        </div>

        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- Name -->
            <div>
                <label asp-for="Contact.Name" class="block text-sm font-medium text-swamp-700 mb-1"></label>
                <input asp-for="Contact.Name"
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="Viggo The Frogger" />
                <span asp-validation-for="Contact.Name" class="text-red-500 text-sm"></span>
            </div>

            <!-- Email -->
            <div>
                <label asp-for="Contact.Email" class="block text-sm font-medium text-swamp-700 mb-1"></label>
                <input asp-for="Contact.Email" type="email"
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="student@swamp.edu" />
                <span asp-validation-for="Contact.Email" class="text-red-500 text-sm"></span>
            </div>

            <!-- Subject -->
            <div>
                <label asp-for="Contact.Subject" class="block text-sm font-medium text-swamp-700 mb-1"></label>
                <select asp-for="Contact.Subject"
                        class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent">
                    <option value="">Select a topic...</option>
                    <option>General Question</option>
                    <option>Bug Report</option>
                    <option>Feature Request</option>
                    <option>Partnership</option>
                </select>
                <span asp-validation-for="Contact.Subject" class="text-red-500 text-sm"></span>
            </div>

            <!-- Message -->
            <div>
                <label asp-for="Contact.Message" class="block text-sm font-medium text-swamp-700 mb-1"></label>
                <textarea asp-for="Contact.Message" rows="5"
                          class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                          placeholder="Type your message here..."></textarea>
                <span asp-validation-for="Contact.Message" class="text-red-500 text-sm"></span>
            </div>

            <!-- Submit -->
            <div class="text-center">
                <button type="submit"
                        class="bg-swamp-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-swamp-600 transition-colors flex items-center justify-center space-x-2 mx-auto shadow-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span>Send Message</span>
                </button>
            </div>
        </form>
    </div>
</section>

@if (Model.ShowSuccess)
{
    <div id="contactSuccess"
         class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-[100]">
        <div class="bg-white rounded-xl max-w-md w-full p-6 shadow-lg">
            <div class="text-center">
                <div class="mx-auto w-24 h-24 bg-swamp-100 rounded-full flex items-center justify-center mb-4">
                    <img src="~/green-toad-wink.svg" alt="Success" class="w-16 h-16">
                </div>
                <h3 class="text-xl font-bold text-swamp-900 mb-2">Message Sent!</h3>
                <p class="text-swamp-700">We'll hop to it! Expect a response within 24-48 hours.</p>
                <button onclick="document.getElementById('contactSuccess').style.display='none'"
                        class="mt-6 bg-swamp-500 text-white px-6 py-2 rounded-full hover:bg-swamp-600 transition-colors">
                    Ribbitastic!
                </button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
